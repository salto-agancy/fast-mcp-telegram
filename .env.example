# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Telegram API Credentials (required)
# Get these from https://my.telegram.org/apps
#
# Two authentication methods (pick one):
#   1) User account (phone + OTP): API_ID + API_HASH + PHONE_NUMBER (run --setup)
#   2) Bot account (no phone, no OTP): API_ID + API_HASH + BOT_API_TOKEN (auto-auth)
API_ID=your_api_id
API_HASH=your_api_hash

# Bot token from @BotFather (alternative to phone-based setup)
# When set, the server auto-authenticates on startup if no session file exists.
# BOT_API_TOKEN=1234567890:ABCdef...GHIjkl

# Domain for HTTP mode (required for production)
# Public host for web setup, MCP URL generation, and attachment_download_url.
# Use hostname only (https:// added) or full URL.
# Placeholder your-domain.com disables attachment URLs.
DOMAIN=your-domain.com

# =============================================================================
# OPTIONAL SERVER SETTINGS
# =============================================================================

# Server mode: stdio (development), http-no-auth (dev server), http-auth (production)
# Default: stdio
SERVER_MODE=http-auth

# Host binding (auto-adjusts: 127.0.0.1 for stdio, 0.0.0.0 for HTTP)
# Default: 127.0.0.0
HOST=0.0.0.0

# Service port
# Default: 8000
PORT=8000

# =============================================================================
# OPTIONAL SESSION SETTINGS
# =============================================================================

# LRU cache limit for concurrent sessions
# Default: 10
MAX_ACTIVE_SESSIONS=10

# Prefix MCP tool names per Bearer session (one agent, multiple MCP connections)
# Not for ordinary multi-user servers (one token per user). @username or user ID. Default: false
PREFIX_MCP_TOOLS_WITH_ACCOUNT=false

# Custom session directory
# Default: ~/.config/fast-mcp-telegram/
SESSION_DIR=

# TTL for temporary setup sessions (seconds)
# Default: 900
SETUP_SESSION_TTL_SECONDS=900

# =============================================================================
# OPTIONAL SECURITY SETTINGS
# =============================================================================

# Allow HTTP URLs for file downloads (insecure, for development only)
# Default: false
ALLOW_HTTP_URLS=false

# Maximum file size for downloads (MB)
# Default: 50
MAX_FILE_SIZE_MB=50

# Block access to private IP ranges (SSRF protection)
# Default: true
BLOCK_PRIVATE_IPS=true

# Session ACL — per-token agent guardrails (http-auth only; not stdio / http-no-auth)
# Default: false. Startup fails closed if enabled but config file missing/invalid.
ACL_ENABLED=false
# Override default {session_directory}/acl.yaml (see acl.yaml.example)
# ACL_CONFIG_PATH=

# How long a minted attachment UUID remains valid (seconds). In-memory; restart invalidates all.
# Default: 3600
ATTACHMENT_TICKET_TTL_SECONDS=3600

# =============================================================================
# OPTIONAL MTPROTO PROXY SETTINGS
# =============================================================================

# MTProto proxy for connecting to Telegram through a proxy
# Format: tg://proxy?server=host&port=443&secret=xxx
# Or: host:port:secret
# MTPROTO_PROXY=tg://proxy?server=your_proxy&port=443&secret=your_secret

# Maximum number of entities to cache per Telegram client
# Default: 1000
ENTITY_CACHE_LIMIT=1000

# =============================================================================
# OPTIONAL LOGGING
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR
# Default: DEBUG
LOG_LEVEL=INFO

# =============================================================================
# SSH DEPLOYMENT (required for sync-remote-config.sh or GitHub Actions)
# =============================================================================

SSH_USER=your_server_user
SSH_HOST=your.server.com
# SSH port (default: 22)
SSH_PORT=22
# Path to SSH private key (optional, if not using ~/.ssh/)
# SSH_KEY=/path/to/private_key

# =============================================================================
# GITHUB CONTAINER REGISTRY (optional, for private images)
# =============================================================================

# GHCR_PULL_USER=your_github_username
# GHCR_PULL_TOKEN=your_github_pat_with_packages_read_scope
