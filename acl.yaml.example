# Per-principal MCP limits (http-auth): which chats each principal may use and what tools it may call.
# Principals omitted from this file keep full tool access when ACL is enabled.
# Set ACL_ENABLED=true; default path {session_directory}/acl.yaml or ACL_CONFIG_PATH.
# See docs/adr/0001-agent-scoped-session-acl.md and docs/research/acl-design-brief.md.
#
# Terminology (see SECURITY.md):
#   Principal — one hosted MCP session (Telegram account) with lane rules below.
#   Principal identifier — key under principals: (today = same string as Bearer + {id}.session).
#   Bearer token — HTTP credential only; not the ACL policy noun.
#   Chat ref — entry in chats: (id, @handle, me); not a principal.
#
# Shared-host checklist: when ACL_ENABLED=true on a shared http-auth host, uncomment
# blocked_peers below (or define your own list). Without blocked_peers, lane ACL alone
# does not block login-code chats or BotFather — teammates sharing a principal identifier
# can still reach those peers via MCP tools.
#
# Use numeric peer ids when possible. @handle lines help block usernames in tool arguments.
# After get_chat_info / get_messages run, results are checked using resolved id and username.
#
# blocked_peers:
#   - 777000          # Telegram service — login codes, security alerts
#   - 93372553        # @BotFather — bot tokens, settings
#   - 178220800       # @SpamBot — spam/limit appeals
#   - "@BotFather"    # optional pre-check alias
#   - "@SpamBot"

principals:
  # Agent profile: analyst (read-only lane — Saved Messages only)
  "REPLACE_WITH_BEARER_TOKEN":
    chats:
      - me
    read_only: true
    allow_global_search: true
    # allow_mtproto: false   # default for listed principals

  # Agent profile: team_lane — work chats, send allowed
  # "another-principal-id":
  #   chats:
  #     - -1001234567890
  #     - "@myteam"
  #   read_only: false
  #   allow_global_search: true
  #   allow_mtproto: false

  # Agent profile: bot — channels only, no global search
  # "automation-principal-id":
  #   chats:
  #     - -100999888777
  #   read_only: false
  #   allow_global_search: false
  #   allow_mtproto: false

  # Optional: listed principal that may use raw MTProto (use sparingly; see SECURITY.md)
  # "power-principal-id":
  #   chats:
  #     - me
  #     - "@workgroup"
  #   read_only: false
  #   allow_global_search: true
  #   allow_mtproto: true
